/* 艾宾浩斯页面样式 */
.container {
  padding: 20rpx 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 页面标题 */
.page-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  color: #c7d1ff;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.page-subtitle {
  display: block;
  font-size: 24rpx;
  color: #8a94a6;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(26, 35, 69, 0.6);
  border: 1rpx solid rgba(130, 150, 255, 0.2);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 40rpx;
  color: #c7d1ff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #8a94a6;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(130, 150, 255, 0.2);
}

/* 混合模式横条 */
.mixed-mode-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: linear-gradient(90deg, rgba(255, 215, 0, 0.15), rgba(255, 185, 87, 0.15));
  border: 2rpx solid rgba(255, 215, 0, 0.4);
  border-radius: 16rpx;
  padding: 28rpx 20rpx;
  margin-bottom: 24rpx;
  transition: all 0.2s;
}

.mixed-mode-bar.active {
  background: linear-gradient(90deg, rgba(255, 215, 0, 0.3), rgba(255, 185, 87, 0.3));
  border-color: rgba(255, 215, 0, 0.6);
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.2);
}

.mixed-icon {
  font-size: 40rpx;
}

.mixed-text {
  font-size: 32rpx;
  color: #ffd700;
  font-weight: 500;
}

.mixed-count {
  font-size: 24rpx;
  color: #ffb957;
  background: rgba(0, 0, 0, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 分类选择 */
.category-section {
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #aabbff;
  margin-bottom: 16rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.category-item {
  background: rgba(26, 35, 69, 0.5);
  border: 1rpx solid rgba(130, 150, 255, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  transition: all 0.2s;
}

.category-item.active {
  background: rgba(106, 133, 255, 0.3);
  border-color: rgba(106, 133, 255, 0.5);
}

.category-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.category-name {
  display: block;
  font-size: 24rpx;
  color: #c7d1ff;
  margin-bottom: 4rpx;
}

.category-count {
  display: block;
  font-size: 20rpx;
  color: #8a94a6;
}

/* 学习区域 */
.learning-section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.mode-toggle {
  padding: 10rpx 20rpx;
  background: rgba(106, 133, 255, 0.2);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #aabbff;
}

/* 单词卡片 */
.word-card {
  background: rgba(26, 35, 69, 0.7);
  border: 1rpx solid rgba(130, 150, 255, 0.3);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.word-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.word-category {
  font-size: 22rpx;
  color: #8a94a6;
  background: rgba(130, 150, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.difficulty-stars {
  font-size: 20rpx;
}

.word-content {
  text-align: center;
  margin-bottom: 30rpx;
}

.word-en-large {
  display: block;
  font-size: 52rpx;
  color: #c7d1ff;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.word-phonetic {
  display: block;
  font-size: 26rpx;
  color: #8a94a6;
  margin-bottom: 20rpx;
}

.cn-reveal {
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
  padding: 20rpx;
}

.word-cn-large {
  font-size: 36rpx;
  color: #5fff97;
}

.word-cn-large.hidden {
  display: none;
}

.reveal-hint {
  font-size: 26rpx;
  color: #8a94a6;
}

/* 例句 */
.example-section {
  background: rgba(0, 0, 0, 0.15);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.example-label {
  display: block;
  font-size: 22rpx;
  color: #8a94a6;
  margin-bottom: 10rpx;
}

.example-text {
  display: block;
  font-size: 26rpx;
  color: #d6e0ff;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.example-cn {
  display: block;
  font-size: 24rpx;
  color: #aabbff;
  line-height: 1.5;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.action-buttons view {
  flex: 1;
  padding: 24rpx 10rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
}

.btn-forget {
  background: rgba(255, 100, 100, 0.2);
  color: #ff9999;
}

.btn-vague {
  background: rgba(255, 185, 87, 0.2);
  color: #ffb957;
}

.btn-remember {
  background: rgba(95, 255, 151, 0.2);
  color: #5fff97;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 30rpx;
  background: rgba(26, 35, 69, 0.5);
  border-radius: 16rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #aabbff;
  margin-bottom: 30rpx;
}

/* 进度条 */
.progress-bar {
  position: relative;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 20rpx;
  overflow: hidden;
}

.progress-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: linear-gradient(90deg, #6a85ff, #4a6cff);
  border-radius: 20rpx;
  transition: width 0.3s ease;
}

.progress-text {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  color: #fff;
  z-index: 1;
}

/* 复习列表 */
.review-list-section {
  background: rgba(26, 35, 69, 0.5);
  border: 1rpx solid rgba(130, 150, 255, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.review-scroll {
  max-height: 300rpx;
}

.review-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(130, 150, 255, 0.1);
}

.review-item:last-child {
  border-bottom: none;
}

.review-word {
  flex: 1;
}

.review-en {
  display: block;
  font-size: 28rpx;
  color: #d6e0ff;
}

.review-cn {
  display: block;
  font-size: 24rpx;
  color: #8a94a6;
  margin-top: 4rpx;
}

.review-due {
  font-size: 22rpx;
  color: #ffb957;
  background: rgba(255, 185, 87, 0.1);
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
}

/* 提示区域 */
.tips-section {
  background: rgba(106, 133, 255, 0.1);
  border: 1rpx solid rgba(130, 150, 255, 0.2);
  border-radius: 12rpx;
  padding: 20rpx;
}

.tips-title {
  display: block;
  font-size: 24rpx;
  color: #c7d1ff;
  margin-bottom: 10rpx;
}

.tips-text {
  display: block;
  font-size: 22rpx;
  color: #8a94a6;
  line-height: 1.6;
}
