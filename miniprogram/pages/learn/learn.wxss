/* 学习页面样式 */
.container {
  padding: 20rpx 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #0a1028;
}

/* 页面标题 */
.page-header {
  text-align: center;
  margin-bottom: 30rpx;
  padding-top: 20rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  color: #c7d1ff;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #8a94a6;
}

/* 今日卡片 */
.today-card {
  background: linear-gradient(135deg, rgba(106, 133, 255, 0.2), rgba(74, 108, 255, 0.1));
  border: 2rpx solid rgba(106, 133, 255, 0.3);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.today-title {
  font-size: 28rpx;
  color: #aabbff;
  margin-bottom: 20rpx;
  text-align: center;
}

.today-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.today-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.today-num {
  font-size: 48rpx;
  color: #c7d1ff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.today-label {
  font-size: 24rpx;
  color: #8a94a6;
}

.today-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(130, 150, 255, 0.2);
}

/* 模式选择 */
.mode-section {
  margin-bottom: 30rpx;
}

.mode-card {
  display: flex;
  align-items: center;
  background: rgba(26, 35, 69, 0.6);
  border: 2rpx solid rgba(130, 150, 255, 0.2);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s;
}

.mode-card:active {
  background: rgba(106, 133, 255, 0.15);
  border-color: rgba(106, 133, 255, 0.4);
}

.mode-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
}

.mode-info {
  flex: 1;
}

.mode-name {
  display: block;
  font-size: 32rpx;
  color: #c7d1ff;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.mode-desc {
  display: block;
  font-size: 24rpx;
  color: #8a94a6;
  margin-bottom: 12rpx;
}

.mode-meta {
  display: flex;
  gap: 20rpx;
}

.mode-count {
  font-size: 22rpx;
  color: #aabbff;
  background: rgba(130, 150, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.mode-progress {
  font-size: 22rpx;
  color: #5fff97;
  background: rgba(95, 255, 151, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.mode-arrow {
  font-size: 40rpx;
  color: #8a94a6;
  margin-left: 10rpx;
}

/* 继续学习 */
.continue-section {
  margin-top: 30rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #aabbff;
  margin-bottom: 16rpx;
}

.continue-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 215, 0, 0.1);
  border: 2rpx solid rgba(255, 215, 0, 0.3);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
}

.continue-mode {
  display: block;
  font-size: 30rpx;
  color: #ffd700;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.continue-detail {
  display: block;
  font-size: 24rpx;
  color: #ffb957;
}

.continue-btn {
  background: linear-gradient(90deg, #ffd700, #ffb957);
  color: #1a2345;
  font-size: 26rpx;
  font-weight: 500;
  padding: 12rpx 30rpx;
  border-radius: 24rpx;
}
