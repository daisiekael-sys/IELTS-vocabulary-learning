/* 首页样式 */
.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 英雄区域 */
.hero {
  text-align: center;
  margin-bottom: 50rpx;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  color: #c7d1ff;
  text-shadow: 0 0 20rpx rgba(130, 150, 255, 0.5);
  margin-bottom: 20rpx;
  font-weight: bold;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: #aabbff;
}

/* 模块网格 */
.module-grid {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 50rpx;
}

/* 模块卡片 */
.module-card {
  background: rgba(26, 35, 69, 0.6);
  border: 1rpx solid rgba(130, 150, 255, 0.2);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.module-card:active {
  transform: scale(0.98);
  background: rgba(26, 35, 69, 0.8);
}

.module-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.module-title {
  display: block;
  font-size: 34rpx;
  color: #c7d1ff;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.module-desc {
  display: block;
  font-size: 26rpx;
  color: #aabbff;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.module-btn {
  display: inline-block;
  margin-top: 10rpx;
}

/* 数据管理区域 */
.data-section {
  background: rgba(26, 35, 69, 0.5);
  border: 1rpx solid rgba(130, 150, 255, 0.2);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  color: #c7d1ff;
  margin-bottom: 24rpx;
  text-align: center;
}

.btn-group {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.btn-danger {
  background: rgba(255, 100, 100, 0.2) !important;
  border-color: rgba(255, 100, 100, 0.4) !important;
  color: #ff9999 !important;
}

/* 页脚 */
.footer {
  text-align: center;
  padding: 30rpx 0;
  margin-top: 20rpx;
}

.footer text {
  font-size: 24rpx;
  color: #8a94a6;
}
