/* 同义替换页面样式 */
.container {
  padding: 20rpx 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  position: relative;
}

/* 页面标题 */
.page-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 34rpx;
  color: #c7d1ff;
  font-weight: 500;
}

/* 控制栏 */
.controls {
  background: rgba(26, 35, 69, 0.5);
  border: 1rpx solid rgba(130, 150, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.control-group {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.control-group:last-child {
  margin-bottom: 0;
}

.control-label {
  font-size: 26rpx;
  color: #aabbff;
  margin-right: 16rpx;
  min-width: 130rpx;
}

/* Picker */
.picker {
  background: rgba(26, 35, 69, 0.7);
  border: 1rpx solid rgba(130, 150, 255, 0.3);
  border-radius: 10rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #e6edf7;
  min-width: 180rpx;
}

.picker-arrow {
  font-size: 20rpx;
  margin-left: 10rpx;
}

/* 模式按钮 */
.mode-buttons, .filter-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  flex: 1;
}

.mode-btn, .filter-btn {
  padding: 14rpx 24rpx;
  background: rgba(106, 133, 255, 0.15);
  border: 1rpx solid rgba(130, 150, 255, 0.3);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #aabbff;
  transition: all 0.2s;
}

.mode-btn.active, .filter-btn.active {
  background: linear-gradient(90deg, #5fff97, #3bff7f);
  color: #0e2212;
  border-color: transparent;
}

/* 模式指示器 */
.mode-indicator {
  position: fixed;
  top: 160rpx;
  right: 0;
  padding: 12rpx 20rpx;
  border-radius: 30rpx 0 0 30rpx;
  font-size: 22rpx;
  z-index: 100;
  backdrop-filter: blur(10rpx);
}

.mode-indicator.mode-normal {
  background: rgba(106, 133, 255, 0.25);
  border: 1rpx solid rgba(106, 133, 255, 0.4);
  color: #aabbff;
}

.mode-indicator.mode-hide {
  background: rgba(255, 185, 87, 0.25);
  border: 1rpx solid rgba(255, 185, 87, 0.4);
  color: #ffb957;
}

/* 词汇滚动区域 */
.vocabulary-scroll {
  height: calc(100vh - 380rpx);
}

.vocabulary-list {
  padding-bottom: 40rpx;
}

/* 单元 */
.unit-section {
  margin-bottom: 30rpx;
}

.unit-title {
  font-size: 32rpx;
  color: #c7d1ff;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(130, 150, 255, 0.3);
}

/* 分组 */
.group-section {
  background: rgba(26, 35, 69, 0.4);
  border: 1rpx solid rgba(130, 150, 255, 0.15);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.group-title {
  font-size: 28rpx;
  color: #aabbff;
}

.word-count {
  font-size: 22rpx;
  color: #8a94a6;
}

/* 单词列表 */
.word-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.word-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(26, 35, 69, 0.3);
  border: 1rpx solid rgba(130, 150, 255, 0.1);
  border-radius: 10rpx;
}

.word-item.starred {
  background: rgba(255, 185, 87, 0.15);
  border-color: rgba(255, 185, 87, 0.3);
}

.word-item.starred-double {
  background: rgba(255, 128, 74, 0.15);
  border-color: rgba(255, 128, 74, 0.3);
}

.word-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex: 1;
  margin-right: 20rpx;
}

.word-en {
  font-size: 30rpx;
  color: #d6e0ff;
  font-weight: 500;
}

.word-cn {
  font-size: 26rpx;
  color: #aabbff;
  max-width: 45%;
  text-align: right;
  transition: all 0.3s;
}

.word-cn.hidden {
  opacity: 0;
}

.word-cn.revealed {
  opacity: 1;
  color: #5fff97;
}

/* 星标按钮 */
.star-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #6677cc;
  transition: all 0.2s;
}

.star-btn.starred {
  color: #ffb957;
}

.star-btn.starred-double {
  color: #ff804a;
}

/* 回到顶部按钮 */
.scroll-top-btn {
  position: fixed;
  bottom: 140rpx;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #6a85ff, #4a6cff);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(106, 133, 255, 0.4);
  opacity: 0;
  visibility: hidden;
  transform: translateY(20rpx);
  transition: all 0.3s ease;
  z-index: 99;
}

.scroll-top-btn.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.scroll-top-btn:active {
  transform: scale(0.9);
}
